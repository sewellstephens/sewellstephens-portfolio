<section class="newsletter-signup">
  <div class="newsletter-signup__content">
    <h3>Newsletter</h3>
    <p class="newsletter-signup__description">Subscribe to my newsletter to get the latest updates and news.</p>
    <form class="newsletter-signup__form" id="newsletter-signup-form">
      <input type="email" id="email" name="email" placeholder="Enter your email" required />
      <button type="submit" id="subscribe-button">Subscribe</button>
    </form>
    <p class="newsletter-signup__confirmation" id="confirmation-message" aria-live="polite"></p>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-signup-form');
  const confirmationMessage = document.getElementById('confirmation-message');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const emailInput = document.getElementById('email');
    const email = emailInput instanceof HTMLInputElement ? emailInput.value : '';

    try {
      const response = await fetch('https://n8n.anchorclick.com/webhook/newsletter', {
        method: 'POST',
        body: JSON.stringify({ email }),
      });

      await response.json();

      if (confirmationMessage) {
        confirmationMessage.textContent = 'Please check your email for a confirmation link.';
      }
    } catch (error) {
      console.error('Error:', error);

      if (confirmationMessage) {
        confirmationMessage.textContent = 'An error occurred. Please try again.';
      }
    }
  });
</script>
